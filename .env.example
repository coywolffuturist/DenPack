# Neon Postgres
NEON_DATABASE_URL=postgresql://...

# LM Studio (Den, tunneled to VPS on :1234)
# The VPS accesses Den's LM Studio via SSH tunnel. See scripts/tunnel-den.sh.
# Run: bash scripts/tunnel-den.sh (keeps tunnel alive in background)
# Den hostname: Coywolfs-Mac-mini.local
# DEN_IP must be the Den's LAN IP (e.g. 192.168.1.x) when accessing directly
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Models
# Arbor (Coordinator/Evaluator) — Gemma 4 E4B, always-on
ARBOR_MODEL=google/gemma-4-e4b
# All workers use Gemma 4 26B MoE — single model, vision on all agents
WORKER_MODEL_PRIMARY=gemma-4-26b-a4b-it
# NOTE: WORKER_MODEL_CODER is deprecated — all workers now use gemma-4-26b-a4b-it
# Sable (Lucid builder) previously used Qwen2.5-Coder — now uses the same Gemma model
WORKER_MODEL_CODER=gemma-4-26b-a4b-it

# VPS memory source (for sync)
VPS_MEMORY_PATH=/home/ubuntu/coywolf/memory

# Den working directory for agent memory snapshots
DEN_AGENT_WORKDIR=/Users/coywolfden/.denpack/agents

# Escalation threshold
ESCALATION_SCORE_THRESHOLD=6.0

# Router port
ROUTER_PORT=3847

# Coordinator (Den)
# DEN_IP must be set to the Den's LAN IP (e.g. 192.168.1.105)
# Run `hostname -I` on the Den or check your router's DHCP table.
# Alternatively, use the SSH tunnel: bash scripts/tunnel-den.sh
# then set COORDINATOR_URL=http://localhost:3848
COORDINATOR_URL=http://DEN_IP:3848
COORDINATOR_PORT=3848

# SimpleMem integration (disabled by default — stub in coordinator/memory-retrieval.ts)
SIMPLEMEM_ENABLED=false

# LEANN integration (disabled by default — stub in coordinator/memory-retrieval.ts)
LEANN_ENABLED=false
